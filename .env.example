# SocialGenius Environment Variables

# Gemini API Key (handled by platform, but for reference)
GEMINI_API_KEY=

# Session secret for Express
SESSION_SECRET=a_very_secret_key_change_me

# OAuth Credentials
# LinkedIn
LINKEDIN_CLIENT_ID=your_linkedin_client_id
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret

# X (Twitter)
TWITTER_CLIENT_ID=your_twitter_client_id
TWITTER_CLIENT_SECRET=your_twitter_client_secret

# Container URL (handled by environment, but for reference if constructing URIs)
APP_URL=
